# Backend
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credix
GOOGLE_CLIENT_ID=
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
REFRESH_TOKEN_TTL_DAYS=30
# Optional SSL controls for hosted Postgres (RDS/Neon/etc.)
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false

# Mobile (Expo public env vars must be prefixed with EXPO_PUBLIC_)
EXPO_PUBLIC_API_URL=http://localhost:3000
